# ─────────────────────────────────────────────────────────────────
# Hayya Med Pro — Environment Variables
# Copy this file to .env.local for local development.
# For production, set all of these in GCP Secret Manager.
# ─────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://pro.hayyamed.pro
# For local dev: http://localhost:3001

# ── Supabase ─────────────────────────────────────────────────────
# Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Paddle (Payments) ────────────────────────────────────────────
# Paddle Dashboard → Developer Tools → API Keys
PADDLE_API_KEY=pdl_live_xxxxxxxxxxxxxxxxxxxxxxxx
# Paddle Dashboard → Developer Tools → Notifications → Webhook secret
PADDLE_WEBHOOK_SECRET=pdlntfset_xxxxxxxxxxxxxxxxxxxxxxxx

# Paddle Price IDs — create products in Paddle first
# Paddle Dashboard → Catalog → Products → create each price
PADDLE_PRO_MONTHLY_PRICE_ID=pri_xxxxxxxxxxxxxxxxxxxxxxxx
PADDLE_PRO_ANNUAL_PRICE_ID=pri_xxxxxxxxxxxxxxxxxxxxxxxx
PADDLE_EMPLOYER_CLINIC_MONTHLY_PRICE_ID=pri_xxxxxxxxxxxxxxxxxxxxxxxx
PADDLE_EMPLOYER_CLINIC_ANNUAL_PRICE_ID=pri_xxxxxxxxxxxxxxxxxxxxxxxx
PADDLE_EMPLOYER_GROWTH_MONTHLY_PRICE_ID=pri_xxxxxxxxxxxxxxxxxxxxxxxx
PADDLE_EMPLOYER_GROWTH_ANNUAL_PRICE_ID=pri_xxxxxxxxxxxxxxxxxxxxxxxx
PADDLE_EMPLOYER_DEPT_MONTHLY_PRICE_ID=pri_xxxxxxxxxxxxxxxxxxxxxxxx
PADDLE_EMPLOYER_DEPT_ANNUAL_PRICE_ID=pri_xxxxxxxxxxxxxxxxxxxxxxxx
PADDLE_EMPLOYER_HOSP_MONTHLY_PRICE_ID=pri_xxxxxxxxxxxxxxxxxxxxxxxx
PADDLE_EMPLOYER_HOSP_ANNUAL_PRICE_ID=pri_xxxxxxxxxxxxxxxxxxxxxxxx

# ── Postmark (Email) ─────────────────────────────────────────────
# Postmark → Servers → API Tokens
POSTMARK_API_TOKEN=your-postmark-server-token
EMAIL_FROM=Hayya Med Pro <noreply@hayyamed.pro>
SUPPORT_EMAIL=support@hayyamed.pro
ADMIN_NOTIFICATION_EMAIL=admin@hayyamed.pro

# ── Anthropic (AI) ───────────────────────────────────────────────
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# ── Web Push / VAPID ─────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:support@hayyamed.pro

# ── PostHog (Analytics) ──────────────────────────────────────────
# posthog.com → Project Settings → Project API Key
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ── Sentry (Error Tracking) ──────────────────────────────────────
# sentry.io → Settings → Projects → your-project → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx
SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx
# sentry.io → Settings → Auth Tokens (for source map uploads in CI)
SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxxxxxxxxxxxxxx
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=hayyamed-pro

# ── Rate Limiting (Upstash Redis) ────────────────────────────────
# console.upstash.com → create database → REST API
# Optional — if omitted, rate limiting is skipped (acceptable for dev)
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── Cron Jobs ────────────────────────────────────────────────────
# Generate a secure random string: openssl rand -hex 32
CRON_SECRET=your-cron-secret-min-32-chars

# ── QPay Qatar Local Payment ─────────────────────────────────────
# QPay Merchant Portal → merchant.qpay.gov.qa
# Apply for a merchant account at qpay.gov.qa
QPAY_BASE_URL=https://merchant.qpay.gov.qa/v2
QPAY_USERNAME=your-qpay-merchant-username
QPAY_PASSWORD=your-qpay-merchant-password
QPAY_INVOICE_CODE=your-qpay-invoice-code

# ── Google Search Console ────────────────────────────────────────
# Google Search Console → Settings → Ownership verification → HTML tag method
# Optional — only needed to verify Search Console ownership
GOOGLE_SITE_VERIFICATION=your-google-site-verification-token
